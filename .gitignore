# ============================================
# FrotaCONF — .gitignore
# ============================================

# ----- Frontend / Node / Vite -----
node_modules/
dist/
dist-ssr/
*.local

# ----- Backend / Java / Maven -----
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd
*.jar
*.war
*.class

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Variáveis de Ambiente / Secrets -----
.env
.env.*
!.env.example

# ----- IDEs e Editores -----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
backend/.idea/
backend/*.iml
*.iml
*.iws
*.ipr

# ----- OS -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Windows / Visual Studio -----
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Misc -----
.gemini/
